# Copy to .env.local and fill in. Never commit .env.local.

# ---- Supabase (server-side data access; service_role bypasses RLS) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Anthropic (AI features) ----
ANTHROPIC_API_KEY=
# Optional model overrides — change the model in one place when one is deprecated.
ANTHROPIC_MODEL_FAST=
ANTHROPIC_MODEL_SMART=
# Optional hard cap on monthly AI spend (USD). Leave blank for no cap.
AI_MONTHLY_USD_BUDGET=

# ---- Instagram / Meta Graph API ----
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional fallback expiry (YYYY-MM-DD) for the token-health readout before the
# token is first stored/refreshed in the DB.
INSTAGRAM_TOKEN_EXPIRES=
# Required for automatic token refresh (Graph token exchange).
META_APP_ID=
META_APP_SECRET=

# ---- Single-user auth gate (the gate is OFF until BOTH are set) ----
APP_PASSWORD=
# Long random string used to sign the session cookie.
AUTH_SECRET=

# ---- Cron ----
# Set in production to lock the daily IG sync endpoint (/api/instagram/sync).
CRON_SECRET=
